# =====================================================
# 智能电子商城 - 环境变量配置示例
# =====================================================
# 使用说明：
# 1. 复制此文件为 .env（在项目根目录）
# 2. 将所有 YOUR_XXX_HERE 替换为真实配置
# 3. .env 文件已被 .gitignore 忽略，不会提交到 Git
# =====================================================

# ==================== AI 模型配置 ====================

# DeepSeek API Key（主模型）
# 获取地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_API_KEY_HERE

# 百度文心一言 API Key（降级备用）
# 获取地址：https://console.bce.baidu.com/qianfan
QIANFAN_API_KEY=YOUR_QIANFAN_API_KEY_HERE
QIANFAN_SECRET_KEY=YOUR_QIANFAN_SECRET_KEY_HERE

# ==================== MCP 工具配置 ====================

# 百度优选 MCP（真实商品购买）
# 获取地址：https://youxuan.baidu.com
BAIDU_YOUXUAN_API_KEY=YOUR_BAIDU_YOUXUAN_API_KEY_HERE

# 飞猪 MCP（机票/酒店预订）
FLIGGY_API_KEY=YOUR_FLIGGY_API_KEY_HERE
FLIGGY_APP_KEY=YOUR_FLIGGY_APP_KEY_HERE

# ==================== Langfuse 追踪配置 ====================

# Langfuse Public Key（从 https://us.cloud.langfuse.com 获取）
LANGFUSE_PUBLIC_KEY=pk-lf-YOUR_PUBLIC_KEY_HERE

# Langfuse Secret Key（请妥善保管，不要泄露）
LANGFUSE_SECRET_KEY=sk-lf-YOUR_SECRET_KEY_HERE

# Langfuse 服务地址
# - US 区域云服务：https://us.cloud.langfuse.com
# - EU 区域云服务：https://cloud.langfuse.com
# - 自托管：http://localhost:3000
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ==================== 数据库配置 ====================

# MySQL 数据库密码
DB_PASSWORD=YOUR_DATABASE_PASSWORD_HERE

# Redis 密码（如果没有密码则留空）
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# ==================== 其他配置 ====================

# 支付宝沙盒配置
ALIPAY_APP_ID=YOUR_ALIPAY_APP_ID_HERE
ALIPAY_PRIVATE_KEY=YOUR_ALIPAY_PRIVATE_KEY_HERE
ALIPAY_PUBLIC_KEY=YOUR_ALIPAY_PUBLIC_KEY_HERE

# Pinecone 向量数据库（RAG 知识库）
PINECONE_API_KEY=YOUR_PINECONE_API_KEY_HERE
PINECONE_ENVIRONMENT=YOUR_PINECONE_ENVIRONMENT_HERE
PINECONE_INDEX_NAME=YOUR_PINECONE_INDEX_NAME_HERE
